# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Default LLM provider: claude | openai | ollama
DEFAULT_LLM=claude
DEFAULT_MODEL=claude-sonnet-4-6

# Ollama local model (if using ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Database (SQLite default — no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./audit_store.db

# For PostgreSQL production:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/bias_auditor

# Analysis settings
RUNS_PER_VARIANT=5
MAX_CONCURRENT_CALLS=10
EMBEDDING_MODEL=all-MiniLM-L6-v2
